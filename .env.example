# Used as HMAC signing secret for session cookies (required)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-a-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Password protecting the dashboard UI (required)
DASHBOARD_PASSWORD="your-secure-password-here"

# Bearer token required on OTEL ingestion requests to convex/http.ts routes.
# Set on the Convex deployment with: npx convex env set OTEL_INGEST_TOKEN <value>
# Send from the Claude Code OTEL exporter as: OTEL_INGEST_TOKEN: <value>
OTEL_INGEST_TOKEN="replace-with-a-random-token"
